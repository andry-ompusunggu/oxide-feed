# ===== Required: Telegram Bot =====
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram Chat ID (private channel or group)
# Negative for groups/channels, e.g., -1001234567890
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===== Required: Google Gemini API (Free Tier) =====
# Get from https://aistudio.google.com/app/apikey
# Satu API key digunakan untuk 2 model Gemini Flash Lite:
#   • gemini-3.5-flash-lite — 475 RPD (PRIMARY — artikel berkualitas)
#   • gemini-3.1-flash-lite — 150 RPD (BACKUP — jika 3.5 kehabisan)
# Total fleet capacity: ~625 RPD — round-robin, 3.5 mendapat prioritas.
#
# 💡 Best Practice: Setelah deploy, pantau log:
#   journalctl -u oxide-feed -f | grep "Router →"
# Untuk melihat distribusi model (seharusnya 3.5 mendominasi).
GEMINI_API_KEY=your_gemini_api_key

# ===== Optional: RSS Configuration =====
# Comma-separated RSS URLs (default: Detik.com RSS)
RSS_FEEDS=https://rss.detik.com/index.php

# Poll interval in minutes (default: 30)
# Trade-off: lebih cepat → delay berita lebih pendek, tapi siklus lebih banyak.
# 30 menit = 48 siklus/hari (sweet spot antara delay & overhead).
POLL_INTERVAL_MINUTES=30

# ===== Optional: Keyword Filters =====
# Whitelist: article title must contain at least one of these (comma-separated, lowercase)
# Default: regulasi,kebijakan,saham,ihsg,bi rate,tarif,bencana,wabah,transjakarta,uu,pemerintah,ekonomi,emiten,rupiah,inflasi
# OXIDE_WHITELIST=regulasi,kebijakan,saham,ihsg

# Blacklist: article title must NOT contain any of these (comma-separated, lowercase)
# Default: viral,netizen,hujat,menikah,selingkuh,pacar,artis,gimmick,fakta menarik,rumor,putus
# OXIDE_BLACKLIST=viral,netizen,artis,gimmick

# ===== Optional: Onboarding Mode =====
# On first boot (no database), process up to N existing articles as a test
# This way you get immediate results without waiting for new articles.
# Set to 0 to disable (default: 0 = skip all existing articles)
# OXIDE_ONBOARDING_COUNT=5

# ===== Optional: Database Maintenance =====
# Auto-delete processed_news records older than N days (0 = disabled)
# Also runs VACUUM every 10 cycles to reclaim disk space.
# Recommended: 30 (monthly cleanup)
# OXIDE_AUTO_VACUUM_DAYS=30

# ===== Optional: Multi-Model Configuration & Throttling =====
# Max articles to process per cycle (0 = unlimited).
# Default: 15 — dengan 2 model (total ~625 RPD / 48 siklus ≈ 13/siklus).
# OXIDE_MAX_ARTICLES_PER_CYCLE=15

# Custom model configuration (JSON array). Overrides default 2-model fleet (Opsi A).
# Default: 3.5-flash-lite (475 RPD, primary) + 3.1-flash-lite (150 RPD, backup).
# Each entry: {"name", "api_base", "rpd_limit", "rpm_limit"}
#
# Rekomendasi alternatif:
#   Opsi B (single model, maximum quality):
#   OXIDE_GEMINI_MODELS='[{"name":"gemini-3.5-flash-lite","api_base":"https://generativelanguage.googleapis.com/v1beta/models/gemini-3.5-flash-lite:generateContent","rpd_limit":475,"rpm_limit":15}]'
#
#   Opsi C (maximum coverage, both equal):
#   OXIDE_GEMINI_MODELS='[{"name":"gemini-3.5-flash-lite","api_base":"https://generativelanguage.googleapis.com/v1beta/models/gemini-3.5-flash-lite:generateContent","rpd_limit":475,"rpm_limit":15},{"name":"gemini-3.1-flash-lite","api_base":"https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-lite:generateContent","rpd_limit":475,"rpm_limit":15}]'

# ===== Optional: Debug / Test Mode =====
# Set to 1 to bypass watermark and process ALL existing articles
# WARNING: This uses Gemini RPD very quickly! Use with caution.
# OXIDE_PROCESS_EXISTING=1

# Set to 1 to print each article's filter status to log
# OXIDE_PRINT_ARTICLES=1
